#!/bin/sh
# AI エージェント（Claude/Codex）のターン完了・承認待ちをデスクトップ通知する。
# terminal-notifier で通知し、クリックで tmux の該当ペインへ復帰する（tmux-focus-pane-hook）。
#
# 使い方:
#   agent-notify claude-stop          # Claude Code Stop フック（stdin に JSON）
#   agent-notify claude-notification  # Claude Code Notification フック（stdin に JSON）
#   agent-notify codex-stop            # Codex Stop フック（stdin に JSON）
#   agent-notify codex-notification    # Codex PermissionRequest フック（stdin に JSON）
#   agent-notify codex '<json>'        # 旧 Codex notify（argv に JSON、後方互換用）
#
# codex exec（非対話実行）から呼ばれた Codex フックは通知しない。
#
set -eu

SELF_DIR="$(unset CDPATH; cd "$(dirname "$0")" && pwd)"
LIB_DIR="$(unset CDPATH; cd "$SELF_DIR/../lib" && pwd)"
. "$LIB_DIR/process.sh"
. "$LIB_DIR/tmux.sh"
. "$LIB_DIR/agent/event.sh"
. "$LIB_DIR/agent/notifier.sh"

mode="${1:-}"

requires_stdout_response=0
if agent_event_requires_stdout_response "$mode"; then
  requires_stdout_response=1
fi

finish() {
  if [ "$requires_stdout_response" -eq 1 ]; then
    printf '{}\n'
  fi
  exit "${1:-0}"
}

# codex exec は自動処理向けなので、完了・承認待ちともデスクトップ通知しない。
case "$mode" in
  codex-stop|codex-notification|codex)
    if agent_event_is_codex_exec; then
      finish 0
    fi
    ;;
esac

agent_notify_rc=0
agent_event_normalize "$mode" "${2:-}" || agent_notify_rc=$?
if [ "$agent_notify_rc" -ne 0 ]; then
  if [ "$agent_notify_rc" -eq 2 ]; then
    printf 'agent-notify: unknown mode: %s\n' "$mode" >&2
  fi
  finish "$agent_notify_rc"
fi

# event.sh は state(working/waiting/idle)+wait_reason を返す。通知の subtitle は
# agent-notify 独自の解釈として、ここで人間向けの日本語ラベルへ変換する
# （notifier.sh は "承認待ち" で通知音を分岐するため、その文言は維持する）。
case "$AGENT_EVENT_STATE" in
  idle)    label="ターン完了" ;;
  working) label="作業中" ;;
  waiting)
    case "$AGENT_EVENT_WAIT_REASON" in
      permission) label="承認待ち" ;;
      question)   label="確認待ち" ;;
      *)          label="入力待ち" ;;
    esac
    ;;
  *) label="$AGENT_EVENT_STATE" ;;
esac

message="$(agent_notifier_message_preview "$AGENT_EVENT_MESSAGE")"
[ -n "$message" ] || message="$label"

# TMUX_PANE が環境に無い（Neovim の :terminal 等）場合は親プロセスから特定する。
pane="${TMUX_PANE:-}"
[ -n "$pane" ] || pane="$(dot_tmux_resolve_pane_via_pid || true)"

# 用事のある tmux ウィンドウへベルマークを付ける（terminal-notifier 未導入・SSH でも機能）。
dot_tmux_send_bell_to_notification_target_window "$pane" "$AGENT_EVENT_CWD"

# status line 右側へ一時通知を出す（issue #55）。SSH でも tmux サーバ側で完結する。
agent_notifier_show_status_line "$pane" "$AGENT_EVENT_CWD" "$AGENT_EVENT_AGENT" "$label"
agent_notifier_send_desktop "$SELF_DIR" "$pane" "$AGENT_EVENT_CWD" "$AGENT_EVENT_AGENT" "$label" "$message"

finish 0
