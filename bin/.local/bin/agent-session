#!/usr/bin/env bash
# 稼働中の AI エージェント（Claude/Codex/Gemini）popup セッションを一覧し、
# fzf picker から復帰（jump）・終了（kill）できるようにする。
#
# 検知は tmux セッションの @agent マーカー（launcher が popup 起動時に種別を刻む。
# lib/tmux.sh の dot_tmux_open_persistent_popup_session 参照）に依存する。セッション
# が終わると agent プロセスも終わり popup セッションも消えるため、tmux のセッション
# 一覧がそのまま「稼働中 agent」の自己掃除されるレジストリになる。
#
# 状態（working/waiting/idle）は @agent_state / @agent_wait_reason として各セッションに
# 刻まれる。刻むのは Claude/Codex のフックから呼ばれる `state`
# サブコマンドで、event.sh が payload を working/waiting/idle + wait_reason へ正規化する
# （agent-notify と同じ分類器を使い、解釈だけ別。issue #52 / #64 参照）。
#
# 使い方:
#   agent-session list             # 稼働中 agent をテキストで一覧表示
#   agent-session pick [session]    # fzf picker を popup で開く（キーバインド入口）
#   agent-session state <mode>      # フックから状態を刻む（stdin に payload）
#   agent-session _picker           # （内部）popup 内で動く fzf 本体
#   agent-session _rows             # （内部）picker の行データ（fzf reload 用）
#
set -uo pipefail

SELF_FILE="$(unset CDPATH; cd "$(dirname "$0")" && pwd)/$(basename "$0")"
LIB_DIR="$(unset CDPATH; cd "$(dirname "$SELF_FILE")/../lib" && pwd)"
# shellcheck source=/dev/null
. "$LIB_DIR/process.sh"
# shellcheck source=/dev/null
. "$LIB_DIR/tmux.sh"

AGENT_SESSION_POPUP_WIDTH="${AGENT_SESSION_POPUP_WIDTH:-90%}"
AGENT_SESSION_POPUP_HEIGHT="${AGENT_SESSION_POPUP_HEIGHT:-90%}"

# picker のヘッダ（通常時）と、kill の二段階確認に使う armed 状態ファイル。
# 状態ファイルのパスは picker と _confirm_kill の両プロセスで同一に解決される。
AGENT_SESSION_HEADER='agent sessions · enter: jump · ctrl-x×2: kill · ctrl-r: refresh'
AGENT_SESSION_KILL_ARMED="${TMPDIR:-/tmp}/agent-session-kill-armed"

# フックから呼ばれ、event.sh の正規化結果を tmux セッションへ刻む。
# 通知は出さない（それは agent-notify の役目）。状態の解釈だけが責務。
agent_session_record_state() {
  agent_session_mode="${1:-}"
  [ -n "$agent_session_mode" ] || return 0

  # shellcheck source=/dev/null
  . "$LIB_DIR/agent/event.sh"
  agent_session_rc=0
  agent_event_normalize "$agent_session_mode" "" || agent_session_rc=$?
  [ "$agent_session_rc" -eq 0 ] || return 0

  # TMUX_PANE が無い実行コンテキストでは親プロセスから pane を特定する。
  agent_session_pane="${TMUX_PANE:-}"
  [ -n "$agent_session_pane" ] || agent_session_pane="$(dot_tmux_resolve_pane_via_pid || true)"
  dot_tmux_mark_agent_state "$agent_session_pane" "$AGENT_EVENT_STATE" "$AGENT_EVENT_WAIT_REASON"
}

# @agent マーカー付きセッションを rank 付きの生データとして出力する（color なし）。
# 形式: rank<TAB>session<TAB>state<TAB>agent<TAB>project
# rank は注意が必要な状態ほど小さく（waiting<idle<unknown<working）。
# list / picker はこれを各々整形する。
agent_session_emit_rows() {
  agent_session_tmux="$(dot_tmux_find_executable)" || return 0
  agent_session_tab="$(printf '\t')"

  "$agent_session_tmux" list-sessions \
    -F '#{session_name}|#{@agent}|#{@agent_state}|#{pane_current_path}' 2>/dev/null \
  | while IFS='|' read -r agent_session_name agent_session_kind agent_session_state \
      agent_session_path; do
      [ -n "$agent_session_kind" ] || continue

      case "$agent_session_state" in
        waiting) agent_session_rank=0 ;;
        idle)    agent_session_rank=1 ;;
        working) agent_session_rank=3 ;;
        *)       agent_session_rank=2 ;;
      esac

      agent_session_project="${agent_session_path##*/}"
      [ -n "$agent_session_project" ] || agent_session_project="$agent_session_name"

      # state は空になり得る（unknown）。空フィールドのままだと読み手の
      # `IFS=<TAB> read` がタブ(空白系IFS)を結合して列がズレるため、none で潰す。
      printf '%s\t%s\t%s\t%s\t%s\n' \
        "$agent_session_rank" "$agent_session_name" "${agent_session_state:-none}" \
        "$agent_session_kind" "$agent_session_project"
    done \
  | sort -t"$agent_session_tab" -k1,1n
}

# state を人間向けのプレーンラベルにする（wait_reason は一覧では出さない）。
agent_session_state_label() {
  case "${1:-}" in
    waiting) printf 'waiting' ;;
    idle)    printf 'idle' ;;
    working) printf 'working' ;;
    *)       printf '?' ;;
  esac
}

# state を ANSI 色付き ● ＋ 固定幅ラベルにする（picker 用）。fzf は --with-nth で選んだ
# フィールドを単純連結し列パディングしないため、ラベルを %-7s で固定幅にして桁を揃える。
agent_session_state_cell() {
  agent_session_cell_label="$(agent_session_state_label "${1:-}")"
  case "${1:-}" in
    waiting) agent_session_cell_color=33 ;;  # yellow: 要対応
    idle)    agent_session_cell_color=32 ;;  # green : 完了・あなたの番
    working) agent_session_cell_color=31 ;;  # red   : 作業中
    *)       agent_session_cell_color=90 ;;  # grey : 不明
  esac
  printf '\033[%sm●\033[0m %-7s' "$agent_session_cell_color" "$agent_session_cell_label"
}

# emit_rows を picker(fzf) 用の行へ整形する。fzf は列パディングしないので、表示部分は
# 自前で固定幅整形した 1 フィールドにまとめ（--with-nth=1 で表示）、可変幅・全角を含み得る
# project を末尾に置いて桁ズレを後続へ波及させない。session は隠しキー（field2 = {2}）。
# 形式: "<colored ●> <state-7> <agent-6> <project>"<TAB>session
agent_session_picker_rows() {
  agent_session_tab="$(printf '\t')"
  agent_session_emit_rows | while IFS="$agent_session_tab" \
    read -r _agent_session_rank agent_session_name agent_session_state \
      agent_session_kind agent_session_project; do
      agent_session_cell="$(agent_session_state_cell "$agent_session_state")"
      printf '%s %-6s %s\t%s\n' \
        "$agent_session_cell" "$agent_session_kind" "$agent_session_project" \
        "$agent_session_name"
    done
}

# 対象 popup セッションへ復帰する。起動元 window へメインクライアントを移してから、
# この popup 内で対象セッションへアタッチし直す（lib の jump 挙動に合わせる）。
agent_session_jump() {
  agent_session_target="${1:-}"
  [ -n "$agent_session_target" ] || return 0

  agent_session_tmux="$(dot_tmux_find_executable)" || return 0
  agent_session_parent="$("$agent_session_tmux" show-options -gqv @agent_picker_parent 2>/dev/null || true)"
  [ -n "$agent_session_parent" ] || agent_session_parent="$(dot_tmux_find_main_client || true)"

  agent_session_pane="$("$agent_session_tmux" display-message -p -t "$agent_session_target" '#{pane_id}' 2>/dev/null || true)"
  agent_session_origin="$(dot_tmux_resolve_origin_window "$agent_session_pane" || true)"
  if [ -n "$agent_session_origin" ] && [ -n "$agent_session_parent" ]; then
    agent_session_origin_session="${agent_session_origin%%|*}"
    agent_session_origin_rest="${agent_session_origin#*|}"
    agent_session_origin_window="${agent_session_origin_rest%%|*}"
    "$agent_session_tmux" switch-client -c "$agent_session_parent" -t "$agent_session_origin_session" 2>/dev/null || true
    "$agent_session_tmux" select-window -t "$agent_session_origin_window" 2>/dev/null || true
  fi

  exec "$agent_session_tmux" attach-session -t "$agent_session_target"
}

# キーバインド入口。popup 内から呼ばれた場合はその popup を閉じてから、メイン
# クライアント上で picker を開く（popup-in-popup を避ける）。
agent_session_pick() {
  agent_session_current="${1:-}"
  agent_session_tmux="$(dot_tmux_find_executable)" || return 0
  [ -n "$agent_session_current" ] || \
    agent_session_current="$("$agent_session_tmux" display-message -p '#{session_name}' 2>/dev/null || true)"

  if [ -n "$agent_session_current" ] && dot_tmux_is_popup_session "$agent_session_current"; then
    "$agent_session_tmux" detach-client -s "$agent_session_current" 2>/dev/null || true
    agent_session_i=0
    while [ "$agent_session_i" -lt 100 ] && dot_tmux_session_has_client "$agent_session_current"; do
      sleep 0.05
      agent_session_i=$((agent_session_i + 1))
    done
  fi

  agent_session_host="$(dot_tmux_find_main_client || true)"
  "$agent_session_tmux" set-option -g @agent_picker_parent "$agent_session_host" 2>/dev/null || true

  if [ -n "$agent_session_host" ]; then
    "$agent_session_tmux" display-popup -c "$agent_session_host" \
      -w "$AGENT_SESSION_POPUP_WIDTH" -h "$AGENT_SESSION_POPUP_HEIGHT" \
      -E "$SELF_FILE _picker"
  else
    "$agent_session_tmux" display-popup \
      -w "$AGENT_SESSION_POPUP_WIDTH" -h "$AGENT_SESSION_POPUP_HEIGHT" \
      -E "$SELF_FILE _picker"
  fi
}

# ctrl-x の二段階確認。同じセッションを armed 状態にし、2 回目で kill を実行する。
# fzf の transform バインドから呼ばれ、次に fzf が実行すべきアクション文字列を出力する。
# 1 回目（未 armed / 別セッション）: 警告ヘッダを出して armed 登録（kill しない）。
# 2 回目（同一セッションが armed 済み）: kill + 一覧 reload + ヘッダを通常へ戻す。
agent_session_confirm_kill() {
  agent_session_target="${1:-}"
  [ -n "$agent_session_target" ] || { printf 'ignore'; return 0; }

  agent_session_tmux="$(dot_tmux_find_executable)" || { printf 'ignore'; return 0; }
  agent_session_armed="$(cat "$AGENT_SESSION_KILL_ARMED" 2>/dev/null || true)"

  if [ "$agent_session_armed" = "$agent_session_target" ]; then
    rm -f "$AGENT_SESSION_KILL_ARMED" 2>/dev/null || true
    printf 'execute-silent(%s kill-session -t %s)+reload(%s _rows)+change-header(%s)' \
      "$agent_session_tmux" "$agent_session_target" "$SELF_FILE" "$AGENT_SESSION_HEADER"
  else
    printf '%s' "$agent_session_target" > "$AGENT_SESSION_KILL_ARMED" 2>/dev/null || true
    printf 'change-header(⚠ %s を終了します — もう一度 ctrl-x で実行 / 別操作で取消)' \
      "$agent_session_target"
  fi
}

# popup 内で動く fzf 本体。enter で jump、ctrl-x ×2 で kill（二段階確認）。
agent_session_picker() {
  agent_session_tmux="$(dot_tmux_find_executable)" || return 0

  if ! command -v fzf >/dev/null 2>&1; then
    "$agent_session_tmux" display-message 'agent-session: fzf が必要です' 2>/dev/null || true
    return 0
  fi

  agent_session_rows="$(agent_session_picker_rows)"
  if [ -z "$agent_session_rows" ]; then
    printf '稼働中の agent セッションはありません\n'
    sleep 1.2
    return 0
  fi

  # 起動のたびに armed 状態を初期化し、前回の取り残しで誤って kill しないようにする。
  rm -f "$AGENT_SESSION_KILL_ARMED" 2>/dev/null || true

  agent_session_sel="$(
    printf '%s\n' "$agent_session_rows" | FZF_DEFAULT_OPTS='' fzf \
      --ansi --delimiter='\t' --with-nth=1 \
      --reverse --cycle \
      --header="$AGENT_SESSION_HEADER" \
      --preview="$agent_session_tmux capture-pane -ept {2}" \
      --preview-window='right,62%,wrap' \
      --bind="ctrl-x:transform:$SELF_FILE _confirm_kill {2}" \
      --bind="ctrl-r:reload($SELF_FILE _rows)"
  )" || true

  [ -n "$agent_session_sel" ] || return 0
  agent_session_target="$(printf '%s' "$agent_session_sel" | cut -f2)"
  agent_session_jump "$agent_session_target"
}

# 人間向けのテキスト一覧。STATE を一番左に、可変幅・全角を含み得る PROJECT を末尾に置く。
agent_session_list() {
  agent_session_tab="$(printf '\t')"
  agent_session_rows="$(agent_session_emit_rows)"
  if [ -z "$agent_session_rows" ]; then
    printf '稼働中の agent セッションはありません\n'
    return 0
  fi
  {
    printf 'STATE\tAGENT\tSESSION\tPROJECT\n'
    printf '%s\n' "$agent_session_rows" | while IFS="$agent_session_tab" \
      read -r _agent_session_rank agent_session_name agent_session_state \
        agent_session_kind agent_session_project; do
        agent_session_label="$(agent_session_state_label "$agent_session_state")"
        printf '%s\t%s\t%s\t%s\n' \
          "$agent_session_label" "$agent_session_kind" "$agent_session_name" \
          "$agent_session_project"
      done
  } | column -ts"$agent_session_tab"
}

case "${1:-list}" in
  list)    agent_session_list ;;
  pick)    agent_session_pick "${2:-}" ;;
  state)   agent_session_record_state "${2:-}" ;;
  _picker) agent_session_picker ;;
  _rows)   agent_session_picker_rows ;;
  _confirm_kill) agent_session_confirm_kill "${2:-}" ;;
  *)
    printf 'agent-session: unknown subcommand: %s\n' "${1:-}" >&2
    printf 'usage: agent-session [list|pick|state <mode>]\n' >&2
    exit 2
    ;;
esac
